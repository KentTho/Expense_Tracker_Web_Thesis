# Backend database. Use your local PostgreSQL database for development.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/expense_tracker_app

# JWT settings. Replace SECRET_KEY locally; never commit a real production key.
SECRET_KEY=change-me-in-local-env
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis cache / Celery broker.
REDIS_URL=redis://localhost:6379/0

# CORS allowlist. Do not use "*" when credentials are enabled.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Firebase Admin.
# Option A: set FIREBASE_SERVICE_ACCOUNT to the full JSON string in your hosting provider.
# Option B: point local tooling to a service account file that is not committed.
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json

# Gemini / chatbot integration.
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Safety guard for reset_alembic.py. Leave disabled by default.
APP_ENV=development
ALLOW_ALEMBIC_RESET=false
CONFIRM_ALEMBIC_RESET=
